{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://patchforge.diiac.io/contracts/compensating_controls_plan.schema.json",
  "title": "PatchForge Compensating Controls Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tenant_id",
    "controls_plan_id",
    "vulnerability_id",
    "controls",
    "effectiveness",
    "review_state"
  ],
  "properties": {
    "tenant_id": { "type": "string", "minLength": 1 },
    "controls_plan_id": { "type": "string", "minLength": 1 },
    "vulnerability_id": { "type": "string", "minLength": 1 },
    "controls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["control_id", "control_type", "description", "owner"],
        "properties": {
          "control_id": { "type": "string", "minLength": 1 },
          "control_type": { "type": "string", "enum": ["network", "identity", "configuration", "monitoring", "process", "ot_operational", "other"] },
          "description": { "type": "string", "minLength": 1 },
          "owner": { "type": "string", "minLength": 1 },
          "expiry": { "type": ["string", "null"], "format": "date" }
        }
      }
    },
    "effectiveness": { "type": "string", "enum": ["strong", "partial", "weak", "unknown"] },
    "evidence_refs": { "type": "array", "items": { "type": "string" }, "default": [] },
    "review_state": { "type": "string", "enum": ["pending_review", "reviewed", "rejected", "superseded"] }
  }
}

