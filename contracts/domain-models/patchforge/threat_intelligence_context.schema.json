{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://patchforge.diiac.io/contracts/threat_intelligence_context.schema.json",
  "title": "PatchForge Threat Intelligence Context",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tenant_id",
    "context_id",
    "vulnerability_id",
    "source_refs",
    "urgency",
    "review_state"
  ],
  "properties": {
    "tenant_id": { "type": "string", "minLength": 1 },
    "context_id": { "type": "string", "minLength": 1 },
    "vulnerability_id": { "type": "string", "minLength": 1 },
    "source_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "kev_listed": { "type": "boolean", "default": false },
    "vendor_observed_exploitation": { "type": "boolean", "default": false },
    "public_exploit_reported": { "type": "boolean", "default": false },
    "urgency": { "type": "string", "enum": ["emergency", "urgent", "standard", "watch", "unknown"] },
    "summary": { "type": "string" },
    "review_state": { "type": "string", "enum": ["pending_review", "reviewed", "rejected", "superseded"] }
  }
}

