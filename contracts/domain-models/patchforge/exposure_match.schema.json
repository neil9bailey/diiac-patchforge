{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PatchForge Exposure Match",
  "type": "object",
  "required": ["id", "customer_id", "asset_id", "cve_id", "match_confidence", "match_reason", "created_at"],
  "properties": {
    "id": { "type": "string" },
    "customer_id": { "type": ["string", "null"] },
    "asset_id": { "type": ["string", "null"] },
    "cve_id": { "type": ["string", "null"] },
    "vendor_id": { "type": ["string", "null"] },
    "product_id": { "type": ["string", "null"] },
    "match_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "match_reason": { "type": "string" },
    "affected_version": { "type": ["string", "null"] },
    "fixed_version": { "type": ["string", "null"] },
    "evidence_refs": { "type": "array", "items": { "type": "string" }, "default": [] },
    "unresolved_gaps": { "type": "array", "items": { "type": ["string", "object"] }, "default": [] },
    "created_at": { "type": "string" }
  }
}
