{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://patchforge.diiac.io/contracts/agent_guidance_snapshot.schema.json",
  "title": "PatchForge Agent Guidance Snapshot",
  "type": "object",
  "required": [
    "tenant_id",
    "snapshot_id",
    "agent_name",
    "advisory_only",
    "can_close_hard_gates",
    "can_approve",
    "can_patch",
    "can_accept_risk",
    "final_approval_issued",
    "human_review_required",
    "verifier_status",
    "created_at"
  ],
  "properties": {
    "tenant_id": { "type": "string" },
    "snapshot_id": { "type": "string" },
    "agent_name": { "type": "string" },
    "provider": { "type": "string", "default": "openai" },
    "model": { "type": "string" },
    "status": { "enum": ["disabled", "verified", "blocked"] },
    "advisory_only": { "const": true },
    "can_close_hard_gates": { "const": false },
    "can_approve": { "const": false },
    "can_patch": { "const": false },
    "can_accept_risk": { "const": false },
    "final_approval_issued": { "default": false, "const": false },
    "human_review_required": { "const": true },
    "evidence_used": { "type": "array", "items": { "type": "object" } },
    "evidence_missing": { "type": "array", "items": { "type": "object" } },
    "source_bound_warnings": { "type": "array", "items": { "type": "string" } },
    "recommended_next_action": { "type": "string" },
    "decision_not_allowed_yet": { "type": "string" },
    "output_hash": { "type": "string" },
    "verifier_status": { "enum": ["not_run", "passed", "blocked"] },
    "verification_failures": { "type": "array", "items": { "type": "object" } },
    "created_at": { "type": "string" }
  }
}
