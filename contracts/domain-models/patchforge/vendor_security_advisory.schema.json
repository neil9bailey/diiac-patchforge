{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://patchforge.diiac.io/contracts/vendor_security_advisory.schema.json",
  "title": "PatchForge Vendor Security Advisory",
  "type": "object",
  "required": ["tenant_id", "advisory_id", "vendor_id", "title", "source_class", "review_state", "evidence_state", "source_bound"],
  "properties": {
    "tenant_id": { "type": "string" },
    "advisory_id": { "type": "string" },
    "vendor_id": { "type": "string" },
    "vendor_name": { "type": ["string", "null"] },
    "cve": { "type": ["string", "null"] },
    "cves": { "type": "array", "items": { "type": "string" } },
    "title": { "type": "string" },
    "summary": { "type": "string" },
    "severity": { "type": "string" },
    "source_class": { "enum": ["vendor_advisory", "cve_record", "ot_vendor_notice", "cloud_provider_advisory"] },
    "source_url": { "type": ["string", "null"] },
    "source_hash": { "type": "string" },
    "affected_products": { "type": "array", "items": { "type": "string" } },
    "affected_versions": { "type": "array", "items": { "type": "string" } },
    "affected_features": { "type": "array", "items": { "type": "string" } },
    "fixed_versions": { "type": "array", "items": { "type": "string" } },
    "known_exploited": { "type": "boolean" },
    "patch_available": { "type": "boolean" },
    "review_state": { "default": "pending_review", "type": "string" },
    "evidence_state": { "default": "referenced", "type": "string" },
    "source_bound": { "const": true },
    "can_close_hard_gates_alone": { "const": false },
    "final_approval_issued": { "default": false, "type": "boolean" }
  }
}
